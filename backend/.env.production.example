# ============================================================
# ICEMGS Backend — Production Environment Variables
# ============================================================
# Copy this file to .env and fill in your production values.

# Django Secret Key — MUST be changed in production!
# Generate one: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-real-secret-key

# Debug mode — MUST be False in production
DEBUG=False

# Allowed hosts — your production domain(s), comma-separated
ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# Database — PostgreSQL connection
DB_NAME=icemgs_db
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=your-db-host.com
DB_PORT=5432

# CORS — frontend origin(s), comma-separated
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# CSRF Trusted Origins — same as CORS origins + backend URL
CSRF_TRUSTED_ORIGINS=https://your-frontend-domain.com,https://your-backend-domain.com

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email (Gmail SMTP with App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# Google Gemini AI API Key (optional — for AI Cost Prediction)
GEMINI_API_KEY=your-gemini-api-key
